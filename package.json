{
    "name": "@nwutils/cli",
    "version": "0.0.2",
    "description": "Command line interface for building NW.js applications",
    "keywords": [
        "NW.js",
        "node-webkit",
        "Desktop",
        "Application"
    ],
    "author": {
        "name": "Ayushman Chhabra",
        "url": "https://ayushmanchhabra.com"
    },
    "maintainers": [
        {
            "name": "Ayushman Chhabra",
            "url": "https://ayushmanchhabra.com"
        }
    ],
    "contributors": [
        {
            "name": "@nwutils/nw-cli Contributors",
            "url": "https://github.com/nwutils/nw-cli/graphs/contributors"
        }
    ],
    "license": "MIT",
    "main": "./src/index.js",
    "bin": {
        "nw-cli": "./bin/cli.js"
    },
    "types": "types",
    "type": "module",
    "files": [
        "LICENSE",
        "src"
    ],
    "homepage": "https://github.com/nwutils/nw-cli",
    "repository": {
        "type": "git",
        "url": "git://github.com/nwutils/nw-cli.git"
    },
    "scripts": {
        "lint": "eslint ./src ./tests",
        "type": "tsc",
        "test": "node --test --experimental-test-coverage --test-coverage-exclude=\"tests/**/*\" \"tests/specs/*.test.js\""
    },
    "dependencies": {
        "@nwutils/getter": "^0.2.2",
        "@nwutils/runner": "^0.2.1",
        "commander": "^14.0.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/chrome": "^0.1.38",
        "@types/node": "^25.5.0",
        "@types/nw.js": "^0.92.0",
        "eslint": "^10.1.0",
        "globals": "^17.4.0",
        "typescript": "^6.0.2"
    },
    "packageManager": "npm@11.12.0",
    "workspaces": [
        "src/templates/*"
    ]
}
